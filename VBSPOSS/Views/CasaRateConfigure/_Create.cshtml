        function paraCasaConfigureBatchGridData() {
            var grid = $("#casaProductGrid").data("kendoGrid");
            if (!grid) return { productCodes: "", accountTypes: "", posCode: "", effectiveDate: "", newInterestRate: "" };

            var selectedRows = grid.select();           // Đây là cách đúng khi dùng columns.Select()
            var productCodes = [];
            var accountTypeCodes = [];

            selectedRows.each(function () {
                var dataItem = grid.dataItem(this);
                if (dataItem) {
                    productCodes.push(dataItem.ProductCode);
                    accountTypeCodes.push(dataItem.AccountTypeCode);
                }
            });

            console.log("Selected ProductCodes:", productCodes);
            console.log("Selected AccountTypeCodes:", accountTypeCodes);

            return {
                productCodes: productCodes.join(","),
                accountTypes: accountTypeCodes.join(","),
                posCode: $("#ApplyPosList").val().join(",") || "",
                effectiveDate: $("#EffectiveDate").val(),
                newInterestRate: $("#NewInterestRate").val()
            };
        }

