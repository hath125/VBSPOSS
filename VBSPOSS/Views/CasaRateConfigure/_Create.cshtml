        function updateSelectedCount(grid) {
            var selectedRows = grid.tbody.find(".k-state-selected");
            var count = selectedRows.length;
            var total = grid.dataSource.total();

            if (count === 0) {
                $("#selectedProducts").text("Tổng số loại tài khoản: " + total);
            } else {
                var codes = [];
                selectedRows.each(function () {
                    var item = grid.dataItem(this);
                    codes.push(item.AccountTypeCode);
                });

                $("#selectedProducts").text("Đã chọn " + count + ": " + codes.join(" | "));

            }
        }

