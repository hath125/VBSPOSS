        function onSave_CasaRateConfigureGrid(e) {
            try {
                // Khởi tạo dirtyFields nếu chưa có

                var posGrade = parseInt($("#PosGrade").val());


                e.model.dirtyFields = e.model.dirtyFields || {};

                var num = e.values.RateProductNewInterestRate;  //
                var model = e.model;

                // Điều kiện cấu hình thêm mới lãi suất
                var rateHO = parseFloat(model.InterestRateHO);
                var minRate = rateHO - parseFloat(model.MinInterestRateSpread);
                var maxRate = rateHO + parseFloat(model.MaxInterestRateSpread);

                // Log
                console.log("rateHO:", rateHO, typeof rateHO);
                console.log("minRate:", minRate, typeof minRate);
                console.log("maxRate:", maxRate, typeof maxRate);
                console.log("newValue:", num, typeof num);

                // Kiểm tra nếu min/max không hợp lệ (null, NaN) → cho phép save hoặc xử lý tùy ý
                if (isNaN(rateHO) || isNaN(minRate) || isNaN(maxRate)) {
                    console.warn("Không tính được min/max spread, bỏ qua validate");
                    // Nếu muốn bắt buộc validate thì alert và preventDefault ở đây
                    // return;
                } else {
                    var newValue = parseFloat(num);
                          if (posGrade !== 3 && ( isNaN(newValue) || newValue < minRate || newValue > maxRate))

                    // if (isNaN(newValue) || newValue < minRate || newValue > maxRate)
                    {
                        alert(
                            "Lãi suất mới phải nằm trong khoảng từ " +
                            kendo.toString(minRate, "n2") +
                            " đến " +
                            kendo.toString(maxRate, "n2") +
                            ". Giá trị bạn nhập không hợp lệ!"
                        );
                        e.preventDefault();  // Ngăn lưu ô này
                        return;              // Dừng xử lý tiếp
                    }
                }

                // Hợp lệ → đánh dấu dirty + highlight ô
                e.model.set("ChangeFlag", 1);
                e.model.dirtyFields["ChangeFlag"] = true;

                for (var field in e.values) {
                    if (e.values.hasOwnProperty(field)) {
                        e.model.dirtyFields[field] = true;

                        if (field === "RateProductNewInterestRate") {
                            updatedCells.push({
                                id: e.model.Id,
                                field: field
                            });

                            // Highlight ô lãi suất mới
                            var row = e.container.closest("tr");
                            var grid = $("#casaRateConfigureGrid").data("kendoGrid");
                            var columnIndex = grid.columns.findIndex(function (col) {
                                return col.field === "RateProductNewInterestRate";
                            });
                            if (columnIndex !== -1) {
                                row.find("td").eq(columnIndex).addClass("cell-updated");
                            }
                        }
                    }
                }

            } catch (error) {
                console.error("Error in onSave_CasaRateConfigureGrid:", error);
            }
        }


    function onRowBound_CasaRateConfigureGrid(e) {
        var grid = this;
        updatedCells.forEach(function (cell) {
            if (cell.field === "RateProductNewInterestRate") {
                var row = grid.tbody.find("tr[data-uid='" + grid.dataSource.get(cell.id).uid + "']");
                if (row.length) {
                    var colIdx = grid.columns.findIndex(c => c.field === "RateProductNewInterestRate");
                    if (colIdx !== -1) {
                        row.find("td").eq(colIdx).addClass("cell-updated");
                    }
                }
            }
        });
    }

    // Hàm lưu
    function onSave_CasaRateConfigureForm() {
        try {
            var grid = $("#casaRateConfigureGrid").data("kendoGrid");
            if (!grid) {
                alert("Lỗi: Không tìm thấy grid!");
                return;
            }
            var decisionNo = $("#CircularRefNum").val().trim();
            if (!decisionNo) {
                alert("Bạn chưa nhập số Quyết định!");
                return;
            }
            var applyPosLst = $("#ApplyPosList").data("kendoMultiSelect").value();
            if (!applyPosLst || applyPosLst.length === 0) {
                alert("Vui lòng chọn ít nhất một POS áp dụng!");
                return;
            }
            // Lấy dữ liệu grid
            var gridData = grid.dataSource.data().toJSON().map(item => ({
                Id: 0,
                RateProductCode: item.RateProductCode,
                RateProductName: item.RateProductName,
                RateProductAccountTypeCode: item.RateProductAccountTypeCode,
                RateProductAccountTypeName: item.RateProductAccountTypeName,
                RateProductAccountSubTypeCode: item.RateProductAccountSubTypeCode || "0",
                RateProductCurrencyCode: item.RateProductCurrencyCode || "VND",
                RateProductDebitCreditFlag: item.RateProductDebitCreditFlag || "C",
                RateProductEffectiveDate: item.RateProductEffectiveDate,
                RateProductExpiredDate: item.RateProductExpiredDate,
                RateProductInterestRate: item.RateProductInterestRate,
                RateProductNewInterestRate: item.RateProductNewInterestRate,
                RateProductPenalRate: item.RateProductPenalRate || 0,
                RateProductPosCode: item.RateProductPosCode,
                RateProductAmoutSlab: item.RateProductAmoutSlab || 0,


                                InterestRateHO: item.InterestRateHO || 0,
        MinInterestRateSpread: item.MinInterestRateSpread || 0,
        MaxInterestRateSpread: item.MaxInterestRateSpread || 0
            }));
            // Lấy dữ liệu form
            var formModel = {
                EffectiveDate: $("#EffectiveDate").data("kendoDatePicker").value(),
                ExpiredDate: $("#ExpiredDate").data("kendoDatePicker").value(),
                CircularDate: $("#CircularDate").data("kendoDatePicker").value(),
                CircularRefNum: $("#CircularRefNum").val(),
                NewInterestRate: $("#NewInterestRate").data("kendoNumericTextBox").value(),
                PenalRate: 0,
                AmoutSlab: 0,
                DebitCreditFlag: "C",
                ApplyPosList: applyPosLst
            };
            var submitData = {
                model: formModel,
                gridItems: gridData
            };
            $.ajax({
                url: '@Url.Action("SaveCasaRateConfigure", "CasaRateConfigure")',
                type: "POST",
                data: JSON.stringify(submitData),
                contentType: "application/json; charset=utf-8",
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                beforeSend: function () {
                    kendo.ui.progress($("#addCasaForm"), true);
                },
                success: function (response) {
                    kendo.ui.progress($("#addCasaForm"), false);
                    if (response.Success) {
                       // alert("Lưu thông tin lãi suất CASA thành công!");
                            alert("Bạn đã tạo thay đổi lãi suất theo quyết định " +  decisionNo + " thành công!");
                        dataChangeCasaRateConfigure = true;
                        mainWindow.data("kendoWindow").close();
                        $("#saveBtn").prop("disabled", true);
                    } else {
                        alert("Lưu thất bại: " + (response.Message || "Unknown error"));
                    }
                },
                error: function (xhr) {
                    kendo.ui.progress($("#addCasaForm"), false);
                    alert("Lỗi server: " + (xhr.responseText || xhr.statusText));
                }
            });
        } catch (error) {
            kendo.ui.progress($("#addCasaForm"), false);
            alert("Lỗi JS: " + error.message);
        }
    }

    function onCloseCasaRateConfigure() {
        if (dataChangeCasaRateConfigure == true) {
            refreshGridCasaRateConfigure(); // Hàm refresh grid Index
            dataChangeCasaRateConfigure = false; // Reset lại
        }
    }

    function paramDonViQL() {
        return {
            pFlagCondi: "5",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "1",
            pUserPosCode: "",
            pFlagAllBank: "0"
        };
    }

    $("#CircularRefNum, #CircularDate").on("change blur", function () {
        var circularRefNum = $("#CircularRefNum").val().trim();
        var datePicker = $("#CircularDate").data("kendoDatePicker");
        var circularDate = datePicker ? datePicker.value() : null;
        $("#qd-status").hide();
        if (!circularRefNum || !circularDate) return;
        $.ajax({
            url: '@Url.Action("CheckCircular", "CasaRateConfigure")',
            type: "GET",
            data: {
                circularRefNum: circularRefNum,
                circularDate: kendo.toString(circularDate, "yyyy-MM-dd")
            },
            success: function (res) {
                if (res.isExists) {
                    $("#qd-status")
                        .html("⚠️")
                        .removeClass("qd-valid")
                        .addClass("qd-invalid")
                        .attr("title", "Quyết định đã tồn tại với ngày này")
                        .show();
                } else if (res.isValid) {
                    $("#qd-status")
                        .html("✔")
                        .removeClass("qd-invalid")
                        .addClass("qd-valid")
                        .attr("title", "Quyết định hợp lệ")
                        .show();
                }
            },
            error: function () {
                $("#qd-status").hide();
            }
        });
    });
</script>


