    <!-- Layout 2 cột: Trái = Grid chọn TK, Phải = Thông tin ngày + lãi suất -->
    <div class="row" style="margin-top: 4px;">
        <!-- CỘT TRÁI: Grid chọn loại tài khoản (50%) -->
        <div class="col-md-6">
            <div style="font-weight:bold; color:blue; margin-bottom:8px;">Danh sách loại tài khoản CASA</div>
            @(Html.Kendo().Grid<dynamic>()
                .Name("casaProductGrid")
                .Columns(columns =>
                {
                    // Cột checkbox chọn tất cả (built-in của Kendo)
                    columns.Select()
                    .Width(50)
                    .HeaderHtmlAttributes(new { style = "text-align:center;" })
                    .HtmlAttributes(new { style = "text-align:center;" });

                    columns.Bound("ProductCode").Title("Mã sản phẩm").Width(100);
                    columns.Bound("AccountTypeCode").Title("Mã loại TK").Width(120);
                    columns.Bound("AccountTypeName").Title("Tên loại TK").Width(250);
                })
                .Selectable(selectable => selectable
                .Mode(GridSelectionMode.Multiple)
                .Type(GridSelectionType.Row)
                )
                .Scrollable(s => s.Height(250))
                .DataSource(ds => ds
                .Ajax()
                .ServerOperation(false)
                .Read(read => read.Action("LoadCasaProductGridData", "CasaRateConfigure").Type(HttpVerbs.Post))
                )
                .Events(e => e.DataBound("onProductGridDataBound")
                .Change("onProductGridDataBound"))
                .AutoBind(true)
                )
            <div id="selectedProducts" style="margin-top:10px; font-weight:bold; color:navy; text-align:center;">
                Đang tải danh sách loại tài khoản...
            </div>
        </div>




        <div class="col-md-6">
            <div style="font-weight:bold; color:blue; margin-bottom:8px; text-align:left;">Thông tin hiệu lực & lãi suất</div>
            <div style="padding:15px; border-radius:6px; border:1px solid #ddd; height:300px;">

                <!-- Hàng 1: Số Quyết định + Ngày quyết định -->
                <div class="row" style="margin-bottom:15px; display: flex; align-items: center; flex-wrap: nowrap; gap: 15px;">
                    <!-- Số Quyết định -->
                    <div style="flex: 1; display: flex; align-items: center; gap: 2px; min-width: 0;">
                        <label style="font-weight:bold; color:navy; margin: 0; white-space:nowrap; min-width: 10px; text-align: right;">
                            Số Quyết định <span style="color:red;">*</span>
                        </label>
                        <div style="flex: 1; display: flex; align-items: center; gap: 2px;">
                            @Html.Kendo().TextBoxFor(m => m.CircularRefNum).HtmlAttributes(new
                                {
                                    id = "CircularRefNum",
                                    style = "flex: 1; color:navy; text-transform:uppercase;"
                                })
                            <span id="qd-status" style="margin-left:8px; display:none;"></span>
                        </div>
                    </div>

                    <!-- Ngày quyết định -->
                    <div style="flex: 1; display: flex; align-items: center; gap: 2px; min-width: 0;">
                        <label style="font-weight:bold; color:navy; margin: 0; white-space:nowrap; min-width: 10px; text-align: right;">
                            Ngày quyết định
                        </label>
                        @Html.Kendo().DatePickerFor(m => m.CircularDate).Format("dd/MM/yyyy").Value(DateTime.Today).HtmlAttributes(new { style = "flex: 1;" })
                    </div>
                </div>

                <!-- Hàng 2: Ngày hiệu lực + Ngày hết hiệu lực -->
                <div class="row" style="margin-bottom:20px; display: flex; align-items: center; flex-wrap: nowrap; gap: 5px;">
                    <!-- Ngày hiệu lực -->
                    <div style="flex: 1; display: flex; align-items: center; gap: 5px; min-width: 0;">
                        <label style="font-weight:bold; color:navy; margin: 0; white-space:nowrap; min-width: 10px; text-align: right;">
                            Ngày hiệu lực <span style="color:red;">*</span>
                        </label>
                        @Html.Kendo().DatePickerFor(m => m.EffectiveDate).Format("dd/MM/yyyy").Value(DateTime.Today.AddDays(1)).HtmlAttributes(new { style = "flex: 1;" })
                    </div>

                    <!-- Ngày hết hiệu lực -->
                    <div style="flex: 1; display: flex; align-items: center; gap: 5px; min-width: 0;">
                        <label style="font-weight:bold; color:navy; margin: 0; white-space:nowrap; min-width: 10px; text-align: right;">
                            Ngày hết hiệu lực
                        </label>
                        @Html.Kendo().DatePickerFor(m => m.ExpiredDate).Format("dd/MM/yyyy").Value(new DateTime(2050, 12, 31)).HtmlAttributes(new { style = "flex: 1;" })
                    </div>
                </div>


                <div class="row" style="margin-bottom:20px;">
                    <div class="col-md-12">
                        <label style=" padding-right:15px">Lãi suất  </label>
                        @Html.Kendo().NumericTextBoxFor(m => m.NewInterestRate).Format("n2").Decimals(2).Min(0).HtmlAttributes(new { style = "width:50%;", placeholder = "Nhập lãi suất chung" })
                    </div>
                </div>

                <!-- Nút Tải dữ liệu & Lưu lại (giữ nguyên) -->
                <div class="create_form row">
                    <div class="col-md-12 d-flex justify-content-end" style="text-align: right; padding-top: 20px;">
                        @(Html.Kendo().Button()
                            .Name("loadDataBtn")
                            .ImageUrl(Url.Content("~/images/tim_kiem.png"))
                            .Content(" Tải dữ liệu")
                            .Events(e => e.Click("onLoadData_CasaRateConfigure"))
                            .HtmlAttributes(new { style = "width:140px; font-weight:bold;" }))
                        @(Html.Kendo().Button()
                            .Name("saveBtn")
                            .ImageUrl(Url.Content("~/images/save-icon.png"))
                            .Content(" Lưu lại")
                            .Events(e => e.Click("onSave_CasaRateConfigureForm"))
                            .HtmlAttributes(new { style = "margin-left:15px; width:120px; font-weight:bold;" }))
                    </div>
                </div>
            </div>
        </div>


    </div>

    <!-- Grid chi tiết lãi suất - full width, dưới cùng -->
    <div class="section-header" style="margin-top: 8px;">
        <div class="section-title">Chi tiết lãi suất các loại tài khoản đã chọn</div>
    </div>

    <div class="row" style="margin-top: 0px;">
        <div class="col-md-12">
            @(Html.Kendo().Grid<CasaRateProductViewModel>()
                .Name("casaRateConfigureGrid")
                .Columns(columns =>
                {
                    columns.Bound(c => c.RateProductCode).Title("Mã sản phẩm").Width(140).Locked(true);
                    columns.Bound(c => c.RateProductAccountTypeCode).Title("Mã loại TK").Width(130).Locked(true);
                    columns.Bound(c => c.RateProductAccountTypeName).Title("Tên loại TK").Width(200).Locked(true);
                    columns.Bound(c => c.RateProductEffectiveDate).Title("Ngày hiệu lực").Format("{0:dd/MM/yyyy}").Width(140).Locked(true);
                    columns.Bound(c => c.RateProductDebitCreditFlag).Title("Dư Nợ/Có").Width(120).Locked(true);
                    columns.Bound(c => c.RateProductInterestRate).Title("Lãi suất hiện tại").Format("{0:n2}").Width(150).Locked(true);
                    columns.Bound(c => c.RateProductNewInterestRate).Title("Lãi suất mới").Format("{0:n2}").Width(130)
                    .HtmlAttributes(new { @class = "new-interest-rate" })
                    .EditorTemplateName("NumericEditor");

                    columns.Bound(c => c.MinInterestRateSpread).Hidden();
                    columns.Bound(c => c.MaxInterestRateSpread).Hidden();
                    //
                })
                .Editable(e => e.Mode(GridEditMode.InCell))  //
                .Scrollable(s => s.Height(450))
                .Events(e => e
                .Edit("onEdit_CasaRateConfigureGrid")
                .Save("onSave_CasaRateConfigureGrid")
                .DataBound("onRowBound_CasaRateConfigureGrid"))
                .DataSource(ds => ds
                .Ajax()
                .Model(m =>
                {
                    m.Id(p => p.Id);
                    m.Field(p => p.RateProductCode).Editable(false); // 🔒 readonly
                    m.Field(p => p.RateProductAccountTypeCode).Editable(false);
                    m.Field(p => p.RateProductEffectiveDate).Editable(false);
                    m.Field(p => p.RateProductDebitCreditFlag).Editable(false);
                    m.Field(p => p.RateProductInterestRate).Editable(false);
                    m.Field(p => p.RateProductAccountTypeName).Editable(false);

                })
                .ServerOperation(false)
                .Read(read => read.Action("LoadCasaConfigureAddGridData", "CasaRateConfigure")
                .Type(HttpVerbs.Post)
                .Data("paraCasaConfigureBatchGridData"))
                .Model(m => m.Id(p => p.Id))
                )
                .AutoBind(false)
                )
        </div>
    </div>
</form>
