        $(document).ready(function () {
       // Chọn check box
        $("#selectAllPos").on("change", function () {
            var checked = this.checked;
            var multiSelect = $("#ApplyPosList").data("kendoMultiSelect");

            if (multiSelect) {
                if (checked) {
                    // Lấy tất cả giá trị có trong DataSource
                    var dataSource = multiSelect.dataSource.data();
                    var allValues = dataSource.map(function(item) {
                        return item.id;
                    });
                    multiSelect.value(allValues);
                } else {
                    multiSelect.value([]);
                }
            }
        });


        $("#ApplyPosList").data("kendoMultiSelect").bind("change", function () {
            var multiSelect = this;
            var dataSource = multiSelect.dataSource.data();
            var selectedCount = multiSelect.value().length;
            var totalCount = dataSource.length;

            $("#selectAllPos").prop("checked", selectedCount === totalCount && totalCount > 0);
        });
    });


</script>